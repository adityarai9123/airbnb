<%- include('partials/head') %>
  </head>
  <body>
    <%- include('partials/nav') %>
<main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
  <h2 class="text-4xl text-red-600 mb-4 font-bold text-center">
    Here are our registered homes :
  </h2>
  <ul class="space-y-4">
    <% registeredHomes.forEach(home => { %>
      <li class="bg-gray-100 shadow-md rounded-lg p-4 flex items-center gap-4 hover:shadow-lg transition-shadow duration-200">
        <div class="w-20 h-20 bg-gray-100 rounded-md flex-shrink-0 overflow-hidden flex items-center justify-center text-gray-400">
          <% if (home.image) { %>
            <img src="<%= home.image %>" alt="<%= home.houseName %>" class="object-cover w-full h-full" />
          <% } else { %>
            <svg class="w-10 h-10 text-gray-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7v13h20V7L12 2zM12 4.2l7 3.2v9.6H5V7.4l7-3.2zM8 14l2.5-3 2.5 3 3.5-4.5L19 12l-7 6-7-6 1-2.5L8 14z"/></svg>
          <% } %>
        </div>

        <div class="flex-1 min-w-0">
          <h3 class="text-lg font-semibold text-gray-900 truncate"><%= home.houseName %></h3>
          <% if (home.location) { %>
            <p class="text-sm text-gray-500 truncate"><%= home.location %></p>
          <% } %>
        </div>

        <div class="text-right flex-shrink-0">
          <% if (home.price) { %>
            <p class="text-sm font-medium text-gray-800">$<%= home.price %>/night</p>
          <% } %>
          <a href="/host/<%= home.id || '' %>" class="inline-block mt-2 text-sm bg-red-500 text-white px-3 py-1 rounded hover:bg-red-400 transition">View Details</a>
        </div>
      </li>
    <% }) %> 
  </ul>
</main>
  </body>
</html>