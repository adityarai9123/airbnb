<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    
    <!-- Page Header -->
    <section class="bg-gradient-to-r from-red-500 to-red-600 text-white py-12">
      <div class="container mx-auto">
        <h1 class="text-4xl font-bold mb-2">All Available Homes</h1>
        <p class="text-red-100">Find and book your perfect home</p>
      </div>
    </section>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-12">
      <!-- Filter Bar -->
      <div class="bg-white rounded-lg shadow-md p-6 mb-12">
        <div class="flex flex-col md:flex-row gap-4">
          <input 
            type="text" 
            id="searchInput" 
            placeholder="Search by location or home name..." 
            class="flex-1 px-4 py-2 border border-gray-300 rounded-lg outline-none focus:ring-2 focus:ring-red-500"
          >
          <input 
            type="number" 
            id="priceFilter" 
            placeholder="Max price" 
            min="0"
            class="w-full md:w-32 px-4 py-2 border border-gray-300 rounded-lg outline-none focus:ring-2 focus:ring-red-500"
          >
          <button onclick="filterHomes()" class="bg-red-500 hover:bg-red-600 text-white px-6 py-2 rounded-lg font-semibold transition">
            <i class="fas fa-filter mr-2"></i>Filter
          </button>
        </div>
      </div>

      <!-- Results Count -->
      <div class="mb-8">
        <p class="text-gray-600"><span id="resultCount"><%= registeredHomes.length %></span> homes found</p>
      </div>

      <!-- Homes Grid -->
      <div id="homesContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% registeredHomes.forEach(home => { %>
          <div class="homeCard bg-white rounded-xl shadow-md overflow-hidden hover:shadow-2xl transition duration-300" 
               data-location="<%= home.location %>" 
               data-price="<%= home.price %>"
               data-name="<%= home.houseName %>">
            <!-- Image Container -->
            <div class="relative overflow-hidden h-64 bg-gray-200">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover hover:scale-110 transition duration-300">
              <div class="absolute top-4 right-4 bg-white rounded-full px-4 py-2 shadow-lg flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-yellow-400">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm font-bold text-gray-800"><%= home.rating %></span>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-800 mb-2"><%= home.houseName %></h3>
              
              <div class="flex items-center text-gray-600 mb-3">
                <i class="fas fa-map-marker-alt mr-2 text-red-500"></i>
                <span class="text-sm"><%= home.location %></span>
              </div>

              <div class="border-t pt-4 mt-4">
                <div class="flex justify-between items-end mb-4">
                  <div>
                    <span class="text-3xl font-bold text-red-500">Rs<%= home.price %></span>
                    <span class="text-gray-600 text-sm ml-1">/ night</span>
                  </div>
                  <% if (home.discountPercent > 0) { %>
                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-semibold">
                      -<%= home.discountPercent %>%
                    </span>
                  <% } %>
                </div>

                <!-- Buttons -->
                <div class="flex gap-2">
                  <a href="/homes/<%= home._id %>" class="flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold py-2 rounded-lg transition text-sm">
                    <i class="fas fa-eye mr-1"></i>View
                  </a>
                  <% if (isLoggedIn && user && user.userType === 'guest') { %>
                    <a href="/book/<%= home._id %>" class="flex-1 text-center bg-red-500 hover:bg-red-600 text-white font-semibold py-2 rounded-lg transition text-sm">
                      <i class="fas fa-calendar mr-1"></i>Book
                    </a>
                  <% } else { %>
                    <a href="/login" class="flex-1 text-center bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 rounded-lg transition text-sm">
                      <i class="fas fa-sign-in-alt mr-1"></i>Login
                    </a>
                  <% } %>
                </div>
                <%- include('../partials/favourite', {home: home}) %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Empty State -->
      <% if (registeredHomes.length === 0) { %>
        <div class="text-center py-16">
          <i class="fas fa-home text-6xl text-gray-300 mb-4"></i>
          <h3 class="text-2xl font-bold text-gray-600 mb-2">No homes available</h3>
          <p class="text-gray-500">Check back soon for amazing listings!</p>
        </div>
      <% } %>
    </main>

    <!-- Filter Script -->
    <script>
      function filterHomes() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const maxPrice = parseFloat(document.getElementById('priceFilter').value) || Infinity;
        const cards = document.querySelectorAll('.homeCard');
        let visibleCount = 0;

        cards.forEach(card => {
          const location = card.dataset.location.toLowerCase();
          const price = parseFloat(card.dataset.price);
          const name = card.dataset.name.toLowerCase();
          
          const matchesSearch = location.includes(searchTerm) || name.includes(searchTerm) || searchTerm === '';
          const matchesPrice = price <= maxPrice;

          if (matchesSearch && matchesPrice) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        document.getElementById('resultCount').textContent = visibleCount;

        if (visibleCount === 0) {
          const container = document.getElementById('homesContainer');
          if (!document.getElementById('noResults')) {
            const noResults = document.createElement('div');
            noResults.id = 'noResults';
            noResults.className = 'col-span-full text-center py-16';
            noResults.innerHTML = `
              <i class="fas fa-search text-6xl text-gray-300 mb-4 block"></i>
              <h3 class="text-2xl font-bold text-gray-600 mb-2">No homes found</h3>
              <p class="text-gray-500">Try adjusting your search or price filter</p>
            `;
            container.appendChild(noResults);
          }
        } else {
          const noResults = document.getElementById('noResults');
          if (noResults) noResults.remove();
        }
      }

      document.getElementById('searchInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') filterHomes();
      });

      document.getElementById('priceFilter').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') filterHomes();
      });
    </script>

  </body>
</html>