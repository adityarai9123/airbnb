<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-red-500 to-red-700 text-white py-20 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <svg class="w-full h-full" viewBox="0 0 1200 400" preserveAspectRatio="none">
          <path d="M0,200 Q300,100 600,200 T1200,200 L1200,400 L0,400 Z" fill="white"/>
        </svg>
      </div>
      <div class="container mx-auto relative z-10">
        <div class="text-center mb-12">
          <h1 class="text-5xl font-bold mb-4">Discover Your Perfect Stay</h1>
          <p class="text-xl text-red-100 mb-8">Find and book amazing homes around the world</p>
        </div>
        
        <!-- Search Bar -->
        <div class="max-w-4xl mx-auto bg-white rounded-full shadow-2xl p-2 flex items-center gap-2">
          <input 
            type="text" 
            id="searchInput" 
            placeholder="Search by location or home name..." 
            class="flex-1 px-6 py-3 text-gray-800 outline-none rounded-full"
          >
          <input 
            type="number" 
            id="priceFilter" 
            placeholder="Max price" 
            min="0"
            class="w-32 px-4 py-3 text-gray-800 outline-none rounded-full border border-gray-300"
          >
          <button onclick="filterHomes()" class="bg-red-500 hover:bg-red-600 text-white px-8 py-3 rounded-full font-semibold transition">
            <i class="fas fa-search mr-2"></i>Search
          </button>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-16">
      <!-- Stats Section -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white rounded-lg shadow-md p-8 text-center hover:shadow-lg transition">
          <div class="text-4xl font-bold text-red-500 mb-2"><%= registeredHomes.length %></div>
          <p class="text-gray-600 font-semibold">Homes Available</p>
        </div>
        <div class="bg-white rounded-lg shadow-md p-8 text-center hover:shadow-lg transition">
          <div class="text-4xl font-bold text-red-500 mb-2">50K+</div>
          <p class="text-gray-600 font-semibold">Happy Guests</p>
        </div>
        <div class="bg-white rounded-lg shadow-md p-8 text-center hover:shadow-lg transition">
          <div class="text-4xl font-bold text-red-500 mb-2">99%</div>
          <p class="text-gray-600 font-semibold">Satisfaction Rate</p>
        </div>
      </div>

      <!-- Section Title -->
      <div class="mb-12">
        <h2 class="text-4xl font-bold text-gray-800 mb-2">Featured Homes</h2>
        <div class="w-20 h-1 bg-red-500 rounded"></div>
      </div>

      <!-- Homes Grid -->
      <div id="homesContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% registeredHomes.forEach(home => { %>
          <div class="homeCard bg-white rounded-xl shadow-md overflow-hidden hover:shadow-2xl transition duration-300 transform hover:scale-105 cursor-pointer" 
               data-location="<%= home.location %>" 
               data-price="<%= home.price %>"
               data-name="<%= home.houseName %>">
            <!-- Image Container -->
            <div class="relative overflow-hidden h-64 bg-gray-200">
              <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-full object-cover">
              <div class="absolute top-4 right-4 bg-white rounded-full px-4 py-2 shadow-lg">
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-yellow-400">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-sm font-bold text-gray-800"><%= home.rating %></span>
                </div>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <h3 class="text-2xl font-bold text-gray-800 mb-2"><%= home.houseName %></h3>
              
              <div class="flex items-center text-gray-600 mb-4">
                <i class="fas fa-map-marker-alt mr-2 text-red-500"></i>
                <span><%= home.location %></span>
              </div>

              <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= home.description %></p>

              <div class="border-t pt-4 mt-4">
                <div class="flex justify-between items-end">
                  <div>
                    <span class="text-3xl font-bold text-red-500">Rs<%= home.price %></span>
                    <span class="text-gray-600 text-sm ml-1">/ night</span>
                  </div>
                  <% if (home.discountPercent > 0) { %>
                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-semibold">
                      Save <%= home.discountPercent %>%
                    </span>
                  <% } %>
                </div>
              </div>

              <!-- Buttons -->
              <div class="mt-6 flex gap-3">
                <a href="/homes/<%= home._id %>" class="flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold py-2 rounded-lg transition">
                  <i class="fas fa-eye mr-2"></i>View Details
                </a>
                <% if (isLoggedIn && user && user.userType === 'guest') { %>
                  <a href="/book/<%= home._id %>" class="flex-1 text-center bg-red-500 hover:bg-red-600 text-white font-semibold py-2 rounded-lg transition">
                    <i class="fas fa-calendar mr-2"></i>Book Now
                  </a>
                <% } else { %>
                  <a href="/login" class="flex-1 text-center bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2 rounded-lg transition">
                    <i class="fas fa-sign-in-alt mr-2"></i>Login to Book
                  </a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Empty State -->
      <% if (registeredHomes.length === 0) { %>
        <div class="text-center py-16">
          <i class="fas fa-home text-6xl text-gray-300 mb-4"></i>
          <h3 class="text-2xl font-bold text-gray-600 mb-2">No Homes Available</h3>
          <p class="text-gray-500">Check back soon for amazing listings!</p>
        </div>
      <% } %>
    </main>

    <!-- Footer CTA Section -->
    <section class="bg-gradient-to-r from-red-500 to-red-600 text-white py-16">
      <div class="container mx-auto text-center">
        <h2 class="text-4xl font-bold mb-4">Can't find what you're looking for?</h2>
        <p class="text-xl text-red-100 mb-8">Browse all our listings or contact support</p>
        <a href="/homes" class="inline-block bg-white text-red-500 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
          View All Homes
        </a>
      </div>
    </section>

    <!-- Search & Filter Script -->
    <script>
      function filterHomes() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const maxPrice = parseFloat(document.getElementById('priceFilter').value) || Infinity;
        const cards = document.querySelectorAll('.homeCard');
        let visibleCount = 0;

        cards.forEach(card => {
          const location = card.dataset.location.toLowerCase();
          const price = parseFloat(card.dataset.price);
          const name = card.dataset.name.toLowerCase();
          
          const matchesSearch = location.includes(searchTerm) || name.includes(searchTerm) || searchTerm === '';
          const matchesPrice = price <= maxPrice;

          if (matchesSearch && matchesPrice) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // Show empty state if no results
        if (visibleCount === 0) {
          const container = document.getElementById('homesContainer');
          if (!document.getElementById('noResults')) {
            const noResults = document.createElement('div');
            noResults.id = 'noResults';
            noResults.className = 'col-span-full text-center py-16';
            noResults.innerHTML = `
              <i class="fas fa-search text-6xl text-gray-300 mb-4 block"></i>
              <h3 class="text-2xl font-bold text-gray-600 mb-2">No homes found</h3>
              <p class="text-gray-500">Try adjusting your search or price filter</p>
            `;
            container.appendChild(noResults);
          }
        } else {
          const noResults = document.getElementById('noResults');
          if (noResults) noResults.remove();
        }
      }

      // Allow Enter key to search
      document.getElementById('searchInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') filterHomes();
      });

      document.getElementById('priceFilter').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') filterHomes();
      });
    </script>

  </body>
</html>