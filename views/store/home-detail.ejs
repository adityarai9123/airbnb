<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>
  <body class="bg-gray-50">
    <%- include('../partials/nav') %>
    
    <!-- Breadcrumb -->
    <div class="bg-gray-100 border-b">
      <div class="container mx-auto px-4 py-4">
        <a href="/" class="text-red-500 hover:text-red-700">Home</a>
        <span class="text-gray-600 mx-2">/</span>
        <a href="/homes" class="text-red-500 hover:text-red-700">All Homes</a>
        <span class="text-gray-600 mx-2">/</span>
        <span class="text-gray-800"><%= home.houseName %></span>
      </div>
    </div>

    <main class="container mx-auto px-4 py-12">
      <!-- Main Content -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Left Side - Images and Details -->
        <div class="lg:col-span-2">
          <!-- Main Image -->
          <div class="rounded-xl overflow-hidden shadow-lg mb-8">
            <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-96 object-cover">
          </div>

          <!-- Details Section -->
          <div class="bg-white rounded-xl shadow-md p-8 mb-8">
            <!-- Title and Rating -->
            <div class="flex justify-between items-start mb-6">
              <div>
                <h1 class="text-4xl font-bold text-gray-800 mb-2"><%= home.houseName %></h1>
                <div class="flex items-center gap-2">
                  <div class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-yellow-400">
                      <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                    </svg>
                    <span class="ml-2 font-semibold text-gray-800"><%= home.rating %> / 5</span>
                  </div>
                </div>
              </div>
              <div class="text-right">
                <span class="text-4xl font-bold text-red-500">Rs<%= home.price %></span>
                <p class="text-gray-600">per night</p>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-center text-gray-700 mb-8 pb-8 border-b">
              <i class="fas fa-map-marker-alt text-red-500 text-xl mr-3"></i>
              <span class="text-lg"><%= home.location %></span>
            </div>

            <!-- Description -->
            <div class="mb-8 pb-8 border-b">
              <h2 class="text-2xl font-bold text-gray-800 mb-4">About this home</h2>
              <p class="text-gray-700 leading-relaxed text-lg"><%= home.description %></p>
            </div>

            <!-- Key Features -->
            <div class="mb-8 pb-8 border-b">
              <h2 class="text-2xl font-bold text-gray-800 mb-4">Key Features</h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                <div class="flex items-center">
                  <i class="fas fa-users text-red-500 mr-3 text-xl"></i>
                  <div>
                    <p class="text-gray-600 text-sm">Guests</p>
                    <p class="font-semibold"><%= home.maxGuests %> people</p>
                  </div>
                </div>
                <% if (home.discountPercent > 0) { %>
                  <div class="flex items-center">
                    <i class="fas fa-tag text-red-500 mr-3 text-xl"></i>
                    <div>
                      <p class="text-gray-600 text-sm">Discount</p>
                      <p class="font-semibold"><%= home.discountPercent %>% off</p>
                    </div>
                  </div>
                <% } %>
                <div class="flex items-center">
                  <i class="fas fa-star text-yellow-400 mr-3 text-xl"></i>
                  <div>
                    <p class="text-gray-600 text-sm">Rating</p>
                    <p class="font-semibold"><%= home.rating %> stars</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- House Rules -->
            <% if (home.rules) { %>
              <div>
                <h2 class="text-2xl font-bold text-gray-800 mb-4">House Rules</h2>
                <p class="text-gray-700 mb-4">Please read the house rules before booking:</p>
                <% if (isLoggedIn) { %>
                  <a href="/rules/<%= home._id %>" class="inline-flex items-center bg-blue-500 hover:bg-blue-600 text-white font-semibold px-6 py-3 rounded-lg transition">
                    <i class="fas fa-download mr-2"></i>Download House Rules (PDF)
                  </a>
                <% } else { %>
                  <p class="text-gray-600 text-sm italic">Please login to download house rules</p>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Right Side - Booking Card -->
        <div>
          <div class="bg-white rounded-xl shadow-lg p-8 sticky top-24">
            <!-- Price Summary -->
            <div class="mb-8">
              <div class="flex justify-between mb-4">
                <span class="text-gray-700">Rs<%= home.price %> × 1 night</span>
                <span class="font-semibold">Rs<%= home.price %></span>
              </div>
              <% if (home.discountPercent > 0) { %>
                <div class="flex justify-between mb-4 text-green-600">
                  <span><%= home.discountPercent %>% Discount</span>
                  <span>-Rs<%= Math.round(home.price * home.discountPercent / 100) %></span>
                </div>
              <% } %>
              <div class="border-t pt-4 flex justify-between text-xl font-bold">
                <span>Total</span>
                <span class="text-red-500">Rs<%= home.price - (home.price * home.discountPercent / 100) %></span>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="space-y-3">
              <% if (isLoggedIn && user && user.userType === 'guest') { %>
                <a href="/book/<%= home._id %>" class="block w-full text-center bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-lg transition">
                  <i class="fas fa-calendar mr-2"></i>Book Now
                </a>
              <% } else if (!isLoggedIn) { %>
                <a href="/login" class="block w-full text-center bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-lg transition">
                  <i class="fas fa-sign-in-alt mr-2"></i>Login to Book
                </a>
                <p class="text-center text-sm text-gray-600">New user? <a href="/signup" class="text-red-500 hover:text-red-700 font-semibold">Sign up</a></p>
              <% } else { %>
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-center">
                  <p class="text-yellow-800 font-semibold">Only guests can book homes</p>
                </div>
              <% } %>

              <% if (isLoggedIn) { %>
                <%- include('../partials/favourite') %>
              <% } %>
            </div>

            <!-- Info Box -->
            <div class="mt-8 pt-8 border-t">
              <p class="text-xs text-gray-500 text-center">
                <i class="fas fa-shield-alt mr-1"></i>
                This home is verified and secure
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>

  </body>
</html>